# Example: load production secrets from HashiCorp Vault KV v2.
# Copy to load-from-vault.sh, set VAULT_ADDR and VAULT_TOKEN, then:
#   bash deploy/secrets/load-from-vault.sh > .env.production

set -euo pipefail

: "${VAULT_ADDR:?Set VAULT_ADDR}"
: "${VAULT_TOKEN:?Set VAULT_TOKEN}"
VAULT_PATH="${VAULT_PATH:-secret/data/boundary-layer}"

vault kv get -format=json "${VAULT_PATH}" | python3 -c '
import json
import sys

payload = json.load(sys.stdin)["data"]["data"]
required = [
    "BOUNDARY_LAYER_ENV",
    "BOUNDARY_LAYER_API_KEY",
    "BOUNDARY_LAYER_METRICS_TOKEN",
    "BOUNDARY_LAYER_ALERT_WEBHOOK_TOKEN",
    "POSTGRES_PASSWORD",
    "SESSION_HMAC_SECRET",
    "REDIS_PASSWORD",
    "BOUNDARY_LAYER_TRUSTED_HOSTS",
    "BOUNDARY_LAYER_RATE_LIMIT_BACKEND",
]
for key in required:
    if key not in payload:
        raise SystemExit(f"Missing key in Vault payload: {key}")
    print(f"{key}={payload[key]}")
'
