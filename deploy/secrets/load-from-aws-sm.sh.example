# Example: load production secrets from AWS Secrets Manager.
# Copy to load-from-aws-sm.sh, configure AWS credentials, then:
#   bash deploy/secrets/load-from-aws-sm.sh > .env.production

set -euo pipefail

SECRET_ID="${SECRET_ID:-boundary-layer/production}"
AWS_REGION="${AWS_REGION:-us-east-1}"

payload="$(aws secretsmanager get-secret-value \
  --region "${AWS_REGION}" \
  --secret-id "${SECRET_ID}" \
  --query SecretString \
  --output text)"

python3 - <<'PY' "${payload}"
import json
import sys

payload = json.loads(sys.argv[1])
defaults = {
    "BOUNDARY_LAYER_ENV": "production",
    "BOUNDARY_LAYER_TRUSTED_HOSTS": "boundary-layer.local,nginx,localhost,api",
    "BOUNDARY_LAYER_RATE_LIMIT_BACKEND": "redis",
}
merged = {**defaults, **payload}
required = [
    "BOUNDARY_LAYER_API_KEY",
    "BOUNDARY_LAYER_METRICS_TOKEN",
    "BOUNDARY_LAYER_ALERT_WEBHOOK_TOKEN",
    "POSTGRES_PASSWORD",
    "SESSION_HMAC_SECRET",
    "REDIS_PASSWORD",
]
for key in required:
    if not str(merged.get(key, "")).strip():
        raise SystemExit(f"Missing key in secret payload: {key}")
for key, value in merged.items():
    print(f"{key}={value}")
PY
