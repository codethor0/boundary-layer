# BoundaryLayer production environment
# Copy to .env.production and replace every CHANGE_ME value before deploy.

BOUNDARY_LAYER_ENV=production

# API authentication (minimum 24 characters each)
BOUNDARY_LAYER_API_KEY=CHANGE_ME-production-api-key-min-24-chars
BOUNDARY_LAYER_METRICS_TOKEN=CHANGE_ME-production-metrics-token-min-24

# Alert webhook authentication
BOUNDARY_LAYER_ALERT_WEBHOOK_TOKEN=CHANGE_ME-production-webhook-token-min-24

# Data store secrets
POSTGRES_PASSWORD=CHANGE_ME-strong-postgres-password
SESSION_HMAC_SECRET=CHANGE_ME-strong-session-hmac-secret
REDIS_PASSWORD=CHANGE_ME-strong-redis-password

# External alert integrations (optional but recommended)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/ME
SLACK_ALERT_CHANNEL=#boundary-layer-alerts
PAGERDUTY_ROUTING_KEY=replace-with-pagerduty-routing-key

# Production TLS host
BOUNDARY_LAYER_TRUSTED_HOSTS=boundary-layer.local,nginx,localhost,api
BOUNDARY_LAYER_RATE_LIMIT_BACKEND=redis

# Optional CORS for browser clients
# BOUNDARY_LAYER_CORS_ENABLED=true
# BOUNDARY_LAYER_CORS_ORIGINS=https://app.example.com
