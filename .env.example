# BoundaryLayer environment variables
# Copy to .env for local overrides (never commit .env)

# API
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info

# Mock LLM
MOCK_LLM_HOST=0.0.0.0
MOCK_LLM_PORT=8080
MOCK_LLM_URL=http://mock-llm:8080

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=boundary_layer
POSTGRES_PASSWORD=boundary_layer_local
POSTGRES_DB=boundary_layer
BOUNDARY_LAYER_POSTGRES_LIVE=true

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
BOUNDARY_LAYER_REDIS_LIVE=true

# Session HMAC (hardened mode)
SESSION_HMAC_SECRET=local-dev-hmac-secret-change-me

# Production profile (see .env.production.example and docs/PRODUCTION.md)
# BOUNDARY_LAYER_ENV=development
# BOUNDARY_LAYER_AUTH_ENABLED=false
# BOUNDARY_LAYER_API_KEY=
# BOUNDARY_LAYER_METRICS_TOKEN=
# BOUNDARY_LAYER_METRICS_AUTH_REQUIRED=false
# BOUNDARY_LAYER_ALLOW_VULNERABLE=true
# BOUNDARY_LAYER_RATE_LIMIT_ENABLED=false
# BOUNDARY_LAYER_LOG_JSON=false
# BOUNDARY_LAYER_RUN_MIGRATIONS=false
# REDIS_PASSWORD=

# Local development outside Docker (example)
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=boundary_layer
# POSTGRES_PASSWORD=boundary_layer_local
# POSTGRES_DB=boundary_layer
# BOUNDARY_LAYER_POSTGRES_LIVE=false
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# BOUNDARY_LAYER_REDIS_LIVE=false

# Prometheus
PROMETHEUS_PORT=9090
